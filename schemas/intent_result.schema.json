{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://major.skill/schemas/intent_result.schema.json",
  "type": "object",
  "title": "MajorIntentResult",
  "description": "major 的意图识别结果。",
  "properties": {
    "intent": {
      "type": "string",
      "enum": [
        "explain_major",
        "compare_majors",
        "compare_countries",
        "recommend_majors",
        "evaluate_fit",
        "university_program_lookup",
        "admissions_lookup",
        "source_check",
        "change_comparison",
        "report_generation",
        "unclear"
      ]
    },
    "confidence": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "countries_detected": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": ["China", "South Korea", "Japan", "United Kingdom", "United States", "Australia"]
      }
    },
    "universities_detected": {
      "type": "array",
      "items": { "type": "string" }
    },
    "majors_detected": {
      "type": "array",
      "items": { "type": "string" }
    },
    "education_level_detected": {
      "type": "string",
      "enum": ["undergraduate", "graduate", "mixed", "unknown"]
    },
    "requires_user_profile": { "type": "boolean" },
    "requires_retrieval": { "type": "boolean" },
    "requires_current_cycle_sources": {
      "type": "boolean",
      "description": "是否需要当前/下一招生周期、当前/下一入学年份、当前/下一 academic year 或 active/current 官方页面来源。"
    },
    "minimum_freshness_floor": {
      "type": "string",
      "description": "最低时效底线，默认 2025-01-01。"
    },
    "currentness_required": {
      "type": "boolean",
      "description": "是否必须证明来源适用于当前或下一周期。"
    },
    "requires_2025_plus_sources": {
      "type": "boolean",
      "description": "Deprecated compatibility field. Prefer requires_current_cycle_sources; this only means 2025-01-01 minimum floor applies."
    },
    "requires_source_citation": { "type": "boolean" },
    "requires_professional_accreditation_warning": { "type": "boolean" },
    "recommended_workflow": {
      "type": "string",
      "enum": [
        "major_explanation_workflow",
        "major_recommendation_workflow",
        "multi_country_comparison_workflow",
        "source_verification_workflow",
        "university_program_lookup_workflow",
        "change_detection_workflow",
        "clarify_scope"
      ]
    },
    "missing_information": {
      "type": "array",
      "items": { "type": "string" }
    },
    "next_action": {
      "type": "string",
      "enum": [
        "answer_directly",
        "ask_clarifying_questions",
        "give_preliminary_direction_then_ask",
        "retrieve_sources",
        "verify_claims",
        "decline_overclaim_and_explain_limits"
      ]
    }
  },
  "required": [
    "intent",
    "confidence",
    "countries_detected",
    "universities_detected",
    "majors_detected",
    "education_level_detected",
    "requires_user_profile",
    "requires_retrieval",
    "requires_current_cycle_sources",
    "minimum_freshness_floor",
    "currentness_required",
    "requires_2025_plus_sources",
    "requires_source_citation",
    "requires_professional_accreditation_warning",
    "recommended_workflow",
    "missing_information",
    "next_action"
  ],
  "additionalProperties": false
}
